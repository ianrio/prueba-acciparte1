{
    "name": "acciparte-backend",
    "version": "1.0.0",
    "description": "API REST multi-tenant para la prueba técnica de Acciparte",
    "type": "module",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "node --watch src/server.js",
        "db:schema": "psql -U postgres -d acciparte -f src/db/schema.sql",
        "db:seed": "node src/db/seed.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.12.0"
    }
}
